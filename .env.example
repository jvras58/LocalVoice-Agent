# Copie para .env e ajuste conforme o ambiente.
# Todas as variáveis usam o prefixo LOCALVOICE_. O prefixo isola a configuração
# do app e evita colisão com variáveis de ferramentas — em especial OLLAMA_HOST,
# usada pelo próprio Ollama para definir o endereço de escuta.

# --- Message broker (Redis) ---
LOCALVOICE_REDIS_URL=redis://localhost:6379
LOCALVOICE_VOICE_COMMANDS_CHANNEL=voice_commands
LOCALVOICE_AGENT_RESPONSES_CHANNEL=agent_responses

# --- LLM local (Ollama) ---
LOCALVOICE_OLLAMA_HOST=http://localhost:11434
LOCALVOICE_OLLAMA_MODEL=llama3.1:8b

# --- Piper TTS ---
# Caminho do modelo de voz .onnx. O .json de configuração é inferido como
# "<modelo>.onnx.json" quando LOCALVOICE_PIPER_CONFIG_PATH não é definido.
LOCALVOICE_PIPER_VOICE_PATH=voices/pt_BR-faber-medium.onnx
# LOCALVOICE_PIPER_CONFIG_PATH=voices/pt_BR-faber-medium.onnx.json
LOCALVOICE_PIPER_USE_CUDA=false

# --- Gateway HTTP/WebSocket ---
LOCALVOICE_GATEWAY_HOST=0.0.0.0
LOCALVOICE_GATEWAY_PORT=8000

# --- TLS (opcional; gere com 'localvoice gen-cert' e sirva com 'localvoice serve') ---
# Quando os dois arquivos existirem, o gateway sobe em HTTPS automaticamente.
# LOCALVOICE_SSL_CERTFILE=certs/localvoice.crt
# LOCALVOICE_SSL_KEYFILE=certs/localvoice.key
