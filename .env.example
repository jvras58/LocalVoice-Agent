# Copie para .env e ajuste conforme o ambiente.
# As variáveis correspondem 1:1 aos campos de src/core/config.py (Settings).

# --- Message broker (Redis) ---
REDIS_URL=redis://localhost:6379
VOICE_COMMANDS_CHANNEL=voice_commands
AGENT_RESPONSES_CHANNEL=agent_responses

# --- LLM local (Ollama) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- Piper TTS ---
# Caminho do modelo de voz .onnx. O .json de configuração é inferido como
# "<modelo>.onnx.json" quando PIPER_CONFIG_PATH não é definido.
PIPER_VOICE_PATH=voices/pt_BR-faber-medium.onnx
# PIPER_CONFIG_PATH=voices/pt_BR-faber-medium.onnx.json
PIPER_USE_CUDA=false

# --- Gateway HTTP/WebSocket ---
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
